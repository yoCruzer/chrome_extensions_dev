{
  "manifest_version": 3,
  "name": "Gemini Chat Backup",
  "version": "0.1.0",
  "description": "Backup Google Gemini conversations as Markdown or ZIP archives.",
  "permissions": ["activeTab", "downloads"],
  "host_permissions": ["https://gemini.google.com/*"],
  "action": {
    "default_title": "Gemini Chat Backup",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content-isolated.js"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content-main.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ]
}
